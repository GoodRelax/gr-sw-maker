# setup.js deploy outputs (suffix-less copies of -ja/-en originals)
# These are generated by `node setup.js <lang>` and should not be committed to the framework repo.
# In user projects (created via `npm init gr-sw-maker`), these ARE the working files.
.claude/agents/*.md
!.claude/agents/*-ja.md
!.claude/agents/*-en.md
.claude/commands/*.md
!.claude/commands/*-ja.md
!.claude/commands/*-en.md
process-rules/*.md
!process-rules/*-ja.md
!process-rules/*-en.md
user-order.md
